<div class="navbar navbar-expand-lg p-1 bg-light mb-2">
  <div class="container-fluid">
    <span class="navbar-text">
      <%= survey.name %>
      <span class="badge bg-secondary">
        <%= survey_public_indicator(survey) %>
      </span>
    </span>
    <div class="d-flex justify-content-end align-items-center">
      <% unless survey.public? %>
        <%= survey_open_indicator(survey) %>
      <% end %>
      <%= copy_survey_button(survey, include_label: true) %>
    </div>
  </div>
</div>
<ul class="nav nav-tabs mb-3" hx-boost="true">
  <li class="nav-item">
    <%= link_to root_path, 'hx-boost': false, class: 'nav-link' do %>
      <%= icon 'fas', 'arrow-left' %> Back to Workspace
    <% end %>
  </li>
  <li class="nav-item">
    <%= link_to survey_path(survey), class: "nav-link #{'active' if selected == :summary}" do %>
      <% if selected == :summary %><%= icon 'fas', 'gauge' %><% end %>
      Summary
    <% end %>
  </li>
  <li class="nav-item">
    <%= link_to survey_data_path(survey), 'hx-boost': false, class: "nav-link #{'active' if selected == :data}" do %>
      <% if selected == :data %><%= icon 'fas', 'table' %><% end %>
      Records
    <% end %>
  </li>
  <li class="nav-item">
    <%= link_to edit_survey_path(survey), class: "nav-link #{'active' if selected == :edit}" do %>
      <% if selected == :edit %><%= icon 'fas', 'pencil' %><% end %>
      Edit
    <% end %>
  </li>
  <li class="nav-item">
    <%= link_to preview_survey_path(survey), class: "nav-link #{'active' if selected == :preview}" do %>
      <% if selected == :preview %><%= icon 'fas', 'eye' %><% end %>
      Preview
    <% end %>
  </li>
  <li class="nav-item">
    <%= link_to share_survey_path(survey), class: "nav-link #{'active' if selected == :share}" do %>
      <% if selected == :share %><%= icon 'fas', 'paper-plane' %><% end %>
      Share
    <% end %>
  </li>
  <li class="nav-item">
    <%= link_to survey_settings_path(survey), class: "nav-link #{'active' if selected == :settings}" do %>
      <% if selected == :settings %><%= icon 'fas', 'gear' %><% end %>
      Settings
    <% end %>
  </li>
</ul>
