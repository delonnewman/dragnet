<div id="tools" class="mb-3 d-flex justify-content-between align-items-center">
  <div>
    <small class="me-1 text-muted d-flex">
      <%= survey_status_indicator(editor.survey) %>
      <% if editor.survey_edited? %>
        Last saved <%= time_ago_in_words editor.last_updated_at %> ago
      <% else %>
        Up to date. Saved <%= time_ago_in_words editor.last_updated_at %> ago
      <% end %>
    </small>
  </div>
  <div class="btn-group">
    <button
      type="button"
      hx-get="<%= preview_survey_path(editor.survey) %>"
      hx-target="#preview-modal-body"
      hx-trigger="click"
      data-bs-toggle="modal"
      data-bs-target="#preview-modal"
      class="btn btn-sm btn-dark">
      <%= icon 'far', 'eye' %>
    </button>
    <button
      type="button"
      class="btn btn-sm btn-dark"
      <%= 'disabled' unless editor.survey_edited? %>
      hx-put="<%= survey_path(editor.survey) %>"
      hx-trigger="click"
      hx-swap="outerHTML"
      hx-target="#tools">
      Publish
    </button>
  </div>
</div>
