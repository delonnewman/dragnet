<div id="details" class="card mb-4 shadow-sm-hover">
  <div class="card-body">
    <div class="card-title pb-3">
        <%= text_field_tag field_name(:survey, :name),
                           survey.name,
                           class: 'h3 border-0 w-100 border-bottom',
                           'hx-put': survey_editor_details_path(survey),
                           'hx-trigger': 'change',
                           'hx-swap': 'outerHTML',
                           'hx-target': '#details',
                           'hx-select-oob': '#tools' %>
        <%= text_area_tag field_name(:survey, :description),
                          survey.description,
                          placeholder: "Description",
                          class: 'form-control',
                          rows: 2,
                          'hx-put': survey_editor_details_path(survey),
                          'hx-trigger': 'change',
                          'hx-swap': 'outerHTML',
                          'hx-target': '#details',
                          'hx-select-oob': '#tools' %>
    </div>
  </div>
</div>
