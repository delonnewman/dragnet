<div class="card question mb-4 shadow-sm-hover<%= question.removed? ? ' text-bg-light-subtle' : question.updated? ? ' border-warning' : '' %>" id="<%= dom_id question %>">
  <div class="card-body">
    <div class="card-title d-flex justify-content-between">
        <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
        <div class="question-title w-100 d-flex me-1">
          <%= text_field_tag field_name(:survey, :question, :text),
                             question.text,
                             id: dom_id(question, :text),
                             title: "Enter question text",
                             class: 'h5 w-100 border-0 border-bottom',
                             disabled: question.removed?,
                             'hx-put': survey_editor_question_path(editor.survey, question),
                             'hx-vals': { authenticity_token: form_authenticity_token }.to_json,
                             'hx-trigger': 'input changed delay:500ms',
                             'hx-target': "#questions",
                             'hx-swap': 'innerHTML' %>
          <% if question.required? %>
            <span title="Required">*</span>
          <% end %>
        </div>
        <%= select_tag field_name(:survey, :question, :type),
                       options_from_collection_for_select(editor.types, :slug, :name, question.type.slug),
                       id: dom_id(question, :type),
                       class: 'form-select w-25',
                       disabled: question.removed?,
                       'hx-put': survey_editor_question_path(editor.survey, question),
                       'hx-vals': { authenticity_token: form_authenticity_token }.to_json,
                       'hx-trigger': 'input, change',
                       'hx-target': "#questions",
                       'hx-swap': 'outerHTML' %>
      <form
        hx-delete="<%= survey_editor_question_path(editor.survey, question) %>"
        hx-target="#questions"
        hx-swap="outerHTML">
        <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
        <button
          type="submit"
          title="Remove"
          class="btn btn-white text-muted" <%= 'disabled' if question.removed? %>>
          <%= icon 'fa-solid', 'xmark' %>
        </button>
      </form>
    </div>
  </div>
</div>
