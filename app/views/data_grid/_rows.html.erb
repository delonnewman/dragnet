<% grid.records.each do |record| %>
  <tr>
    <td class="text-nowrap text-muted">
      <%= fmt_datetime record.created_at %>
    </td>
    <% grid.questions.each do |question| %>
      <td><%= answers_text record, question %></td>
    <% end %>
  </tr>
<% end %>

<% if grid.show_load_more? %>
  <tr id="the-end"
    hx-get="<%= survey_data_rows_path(grid.survey, page: grid.pager.next) %>"
    hx-trigger="revealed"
    hx-swap="outerHTML"
  >
    <td colspan="<%= grid.questions.count + 1 %>">
      <div class="spinner-grow" role="status">
        <span class="visually-hidden">Loading...</span>
      </div>
    </td>
  </tr>
<% end %>
